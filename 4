---
- hosts: web
  remote_user : ubuntu
  become: yes
  tasks:
    - name: Install Docker
      apt:
        name: docker.io
        state: present
        update_cache: yes

    - name: Pull Docker Image
      command: docker pull your-dockerhub-username/myapp:latest

    - name: Stop existing container
      command: docker stop myapp || true

    - name: Remove existing container
      command: docker rm myapp || true

    - name: Run Docker container
      command: docker run -d -p 80:3000 --name myapp your-dockerhub-username/myapp:latest
